# HireReady Backend — Environment Variables
# Copy this to .env and fill in your values

# OpenAI API Key (required)
OPENAI_API_KEY=sk-proj-your-key-here

# Frontend URL(s) for CORS — comma-separated for multiple origins
# Local: http://localhost:5173
# Production: https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=http://localhost:5173

# GitHub OAuth (optional — needed for GitHub sync feature)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/github/callback

# Firebase Storage Bucket (optional — for PDF storage)
FIREBASE_STORAGE_BUCKET=

# Port (auto-set by Railway, default 8000 for local dev)
# PORT=8000
